#!/usr/sbin/nft -f
# /etc/nftables.conf
# Managed by ansible: roles/setup_networking_p2p

flush ruleset

# Dual-stack mangle: mark inbound connections by ingress interface so that
# replies exit the same interface via policy routing (fwmark -> table).
table inet mangle {
    chain prerouting {
        type filter hook prerouting priority mangle; policy accept;
{% if mgmt_iface is defined and internal_iface is defined %}
        iifname "{{ internal_iface }}" ct mark set 0x1
{% endif %}
{% if public_iface is defined %}
        iifname "{{ public_iface }}" ct mark set 0x2
{% endif %}
    }

    chain output {
        type filter hook output priority mangle; policy accept;
{% if mgmt_iface is defined and internal_iface is defined %}
        ct mark 0x1 meta mark set 0x1
{% endif %}
{% if public_iface is defined %}
        ct mark 0x2 meta mark set 0x2
{% endif %}
    }
}
{% if public_iface is defined %}
{% set _base_ports = [
    default_p2p_port | default(''),
    default_cometbft_p2p_port | default(''),
    default_bootnode_p2p_port | default(''),
    default_bootnode_p2p_port_wss | default('')
] | reject('equalto', '') | list %}
{# allowed_additional_public_ports: per-host extra public ports (e.g. [443] for nginx RPC) #}
{% set allowed_ports = (_base_ports + (allowed_additional_public_ports | default([]))) | unique | list %}

# Firewall: restrict inbound on {{ public_iface }} (public) to specific P2P
# ports. The management/NAT and internal interfaces remain unrestricted.
table inet filter {
    chain input {
        type filter hook input priority filter; policy accept;

        # Established/related and loopback always pass
        ct state established,related accept
        iifname "lo" accept

        # ICMP/ICMPv6 needed for ping and IPv6 NDP
        iifname "{{ public_iface }}" meta l4proto { icmp, ipv6-icmp } accept

{% if allowed_ports %}
        # Allowed public P2P ports
        iifname "{{ public_iface }}" tcp dport { {{ allowed_ports | join(', ') }} } accept
{% endif %}

        # Drop everything else arriving on {{ public_iface }}
        iifname "{{ public_iface }}" drop
    }
}
{% endif %}
